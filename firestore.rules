rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Users collection rules
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Sessions collection rules
    match /sessions/{sessionId} {
      // For get and list: resource.data.uid must match the authenticated user
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      // For create: request.resource.data.uid must match the authenticated user
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // For update: both existing document and updated document must be owned by the user
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      // For delete: user must own the document
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Messages collection rules (if used, keep it safe and NPE-free)
    match /messages/{messageId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Promocodes collection rules
    match /promocodes/{code} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // Files collection rules
    match /files/{fileId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
